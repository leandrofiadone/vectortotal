---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../../utils/readingTime';
import { getTagColor } from '../../data/tags';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter(p => !p.data.draft);

  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag.toLowerCase());
    }
  }

  return [...tagSet].map(tag => ({
    params: { tag },
    props: {
      posts: posts
        .filter(p => p.data.tags.map(t => t.toLowerCase()).includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}



const { tag } = Astro.params;
const { posts } = Astro.props;
const tagColor = getTagColor(tag);
---

<BaseLayout
  title={`#${tag}`}
  description={`Posts etiquetados con ${tag} en vectortotal`}
>
  <div class="container page-wrap">
    <nav class="breadcrumb">
      <a href="/">~</a>
      <span class="sep">/</span>
      <a href="/salas">salas</a>
      <span class="sep">/</span>
      <span class="current">tags</span>
      <span class="sep">/</span>
      <span class="current">{tag}</span>
    </nav>

    <header class="tag-header">
      <div class="tag-hero-wrap">
        <span class="tag tag-hero" style={`color: ${tagColor}; border-color: ${tagColor}33; background: ${tagColor}12;`}>{tag}</span>
        <span class="tag-count">{posts.length} {posts.length === 1 ? 'sala' : 'salas'}</span>
      </div>
      <p class="tag-desc">Posts etiquetados con <strong>{tag}</strong></p>
    </header>

    {posts.length === 0 && (
      <p class="empty">No hay salas con esta etiqueta todavía.</p>
    )}

    <div class="post-list">
      {posts.map((post, i) => (
        <PostCard
          title={post.data.title}
          excerpt={post.data.excerpt}
          date={post.data.date}
          tags={post.data.tags}
          slug={post.slug}
          series={post.data.series}
          num={i + 1}
          readingTime={readingTime(post.body)}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 36px;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { opacity: 0.4; }
  .breadcrumb .current { color: var(--accent); }

  .tag-header {
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
  }

  .tag-hero-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .tag-hero {
    font-size: 1rem;
    padding: 6px 14px;
  }

  .tag-count {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 3px;
  }

  .tag-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    font-weight: 300;
  }

  .tag-desc strong {
    color: var(--text);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .empty {
    font-family: var(--mono);
    color: var(--text-dim);
    font-size: 0.85rem;
  }
</style>
