---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SERIES } from '../../data/series';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Agrupar por serie
const seriesMap: Record<string, typeof posts> = {};
for (const post of posts) {
  if (post.data.series) {
    if (!seriesMap[post.data.series]) seriesMap[post.data.series] = [];
    seriesMap[post.data.series].push(post);
  }
}

const seriesEntries = Object.entries(SERIES);
const totalPosts = posts.length;
---

<BaseLayout title="Salas" description="Salas de estudio — apuntes de redes, Linux y seguridad organizados por área." bodyClass="pattern-scan">
  <div class="container page-wrap">
    <header class="page-header">
      <p class="page-label">// salas de estudio</p>
      <h1 class="page-title">Áreas</h1>
      <p class="page-desc">
        {totalPosts} {totalPosts === 1 ? 'sala' : 'salas'} organizadas en {seriesEntries.length} áreas.
        Cada área es un tema que estoy estudiando — protocolos, herramientas, conceptos.
      </p>
    </header>

    <div class="areas-grid">
      {seriesEntries.map(([key, meta]) => {
        const areaPosts = seriesMap[key] ?? [];
        const preview = areaPosts.slice(0, 3);
        return (
          <a href={`/salas/${key}`} class="area-card">
            <div class="card-accent" style={`background: ${meta.color}`}></div>
            <div class="card-body">
              <div class="card-head">
                <span class="card-icon">{meta.icon}</span>
                <div class="card-titles">
                  <h2 class="card-title">{meta.title}</h2>
                  <p class="card-desc">{meta.description}</p>
                </div>
                <span class="card-count">{areaPosts.length}</span>
              </div>

              {preview.length > 0 && (
                <ul class="card-preview">
                  {preview.map(p => (
                    <li class="preview-item">
                      <span class="preview-dot">·</span>
                      <span class="preview-title">{p.data.title}</span>
                    </li>
                  ))}
                  {areaPosts.length > 3 && (
                    <li class="preview-item preview-more">
                      <span class="preview-dot">·</span>
                      <span>+{areaPosts.length - 3} más</span>
                    </li>
                  )}
                </ul>
              )}

              <div class="card-footer">
                <span class="card-cta">explorar área →</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    {seriesEntries.length === 0 && (
      <p class="empty">No hay áreas publicadas aún.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding-top: 48px;
    padding-bottom: 80px;
  }

  .page-header {
    margin-bottom: 48px;
  }

  .page-label {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .page-title {
    font-family: var(--display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--text-bright);
    margin-bottom: 10px;
  }

  .page-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.7;
    font-weight: 300;
    max-width: 520px;
  }

  /* Grid de áreas */
  .areas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 16px;
  }

  .area-card {
    display: flex;
    flex-direction: column;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.15s;
    position: relative;
  }

  .area-card:hover {
    border-color: var(--border-light, rgba(255,255,255,0.12));
    transform: translateY(-2px);
  }

  .card-accent {
    height: 3px;
    width: 100%;
    opacity: 0.7;
    flex-shrink: 0;
  }

  .card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }

  .card-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .card-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .card-titles {
    flex: 1;
    min-width: 0;
  }

  .card-title {
    font-family: var(--display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 4px;
  }

  .card-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.5;
    font-weight: 300;
  }

  .card-count {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 2px;
    white-space: nowrap;
    align-self: flex-start;
  }

  /* Preview de posts */
  .card-preview {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 12px;
    background: var(--bg3);
    border-radius: 4px;
  }

  .preview-item {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .preview-dot {
    font-family: var(--mono);
    color: var(--accent);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .preview-title {
    font-size: 0.78rem;
    color: var(--text-dim);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .preview-more {
    opacity: 0.6;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  .card-footer {
    margin-top: auto;
  }

  .card-cta {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    transition: color 0.2s;
  }

  .area-card:hover .card-cta {
    color: var(--accent);
  }

  .empty {
    font-family: var(--mono);
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .areas-grid { grid-template-columns: 1fr; }
  }
</style>
