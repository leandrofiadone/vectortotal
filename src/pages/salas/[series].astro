---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { SERIES } from '../../data/series';

export async function getStaticPaths() {
  return Object.keys(SERIES).map(series => ({ params: { series } }));
}

function readingTime(body: string): number {
  const text = body
    .replace(/^---[\s\S]*?---/, '')
    .replace(/<[^>]+>/g, ' ')
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`[^`]+`/g, ' ');
  const words = text.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const { series: seriesKey } = Astro.params;
const meta = SERIES[seriesKey];

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.series === seriesKey)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

// Agrupar por subsección si existe
const subsectionMap = new Map<string, typeof posts>();
const noSubsection: typeof posts = [];

for (const post of posts) {
  const sub = post.data.subsection;
  if (sub) {
    if (!subsectionMap.has(sub)) subsectionMap.set(sub, []);
    subsectionMap.get(sub)!.push(post);
  } else {
    noSubsection.push(post);
  }
}

const hasSubsections = subsectionMap.size > 0;
let globalNum = 1;
---

<BaseLayout
  title={meta?.title ?? seriesKey}
  description={meta?.description}
>
  <div class="container page-wrap">
    <nav class="breadcrumb">
      <a href="/">~</a>
      <span class="sep">/</span>
      <a href="/salas">salas</a>
      <span class="sep">/</span>
      <span class="current">{seriesKey}</span>
    </nav>

    <header class="area-header">
      <div class="area-icon-wrap" style={`background: ${meta?.color}18; border-color: ${meta?.color}40`}>
        <span class="area-icon">{meta?.icon ?? '📚'}</span>
      </div>
      <div class="area-info">
        <p class="area-label">// área de estudio</p>
        <h1 class="area-title">{meta?.title ?? seriesKey}</h1>
        {meta?.description && <p class="area-desc">{meta.description}</p>}
      </div>
      <span class="area-count">{posts.length} {posts.length === 1 ? 'sala' : 'salas'}</span>
    </header>

    {posts.length === 0 && (
      <p class="empty">No hay salas en esta área todavía.</p>
    )}

    {hasSubsections ? (
      <>
        {[...subsectionMap.entries()].map(([subKey, subPosts]) => (
          <section class="subsection">
            <div class="subsection-header">
              <span class="subsection-title">{subKey}</span>
              <span class="subsection-count">{subPosts.length}</span>
            </div>
            <div class="post-list">
              {subPosts.map((post) => {
                const n = globalNum++;
                return (
                  <PostCard
                    title={post.data.title}
                    excerpt={post.data.excerpt}
                    date={post.data.date}
                    tags={post.data.tags}
                    slug={post.slug}
                    series={seriesKey}
                    num={n}
                    readingTime={readingTime(post.body)}
                  />
                );
              })}
            </div>
          </section>
        ))}
        {noSubsection.length > 0 && (
          <section class="subsection">
            <div class="subsection-header">
              <span class="subsection-title">General</span>
              <span class="subsection-count">{noSubsection.length}</span>
            </div>
            <div class="post-list">
              {noSubsection.map((post) => {
                const n = globalNum++;
                return (
                  <PostCard
                    title={post.data.title}
                    excerpt={post.data.excerpt}
                    date={post.data.date}
                    tags={post.data.tags}
                    slug={post.slug}
                    series={seriesKey}
                    num={n}
                    readingTime={readingTime(post.body)}
                  />
                );
              })}
            </div>
          </section>
        )}
      </>
    ) : (
      <div class="post-list">
        {posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.slug}
            series={seriesKey}
            num={i + 1}
            readingTime={readingTime(post.body)}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 36px;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { opacity: 0.4; }
  .breadcrumb .current { color: var(--accent); }

  /* Header */
  .area-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 44px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .area-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .area-icon { font-size: 1.6rem; }

  .area-info { flex: 1; min-width: 0; }

  .area-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .area-title {
    font-family: var(--display);
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: var(--text-bright);
    margin-bottom: 8px;
  }

  .area-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.6;
    font-weight: 300;
    max-width: 560px;
  }

  .area-count {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 3px;
    white-space: nowrap;
    align-self: flex-start;
  }

  /* Subsecciones */
  .subsection {
    margin-bottom: 40px;
  }

  .subsection-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .subsection-title {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    flex: 1;
  }

  .subsection-count {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 2px 7px;
    border-radius: 2px;
  }

  /* Posts */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .empty {
    font-family: var(--mono);
    color: var(--text-dim);
    font-size: 0.85rem;
  }
</style>
