---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { SERIES } from '../../data/series';
import { toSlug } from '../../utils/slug';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  return Object.keys(SERIES).map(series => ({ params: { series } }));
}



const { series: seriesKey } = Astro.params;
const meta = SERIES[seriesKey];

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.series === seriesKey)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

// Agrupar por subsección si existe
const subsectionMap = new Map<string, typeof posts>();
const noSubsection: typeof posts = [];

for (const post of posts) {
  const sub = post.data.subsection;
  if (sub) {
    if (!subsectionMap.has(sub)) subsectionMap.set(sub, []);
    subsectionMap.get(sub)!.push(post);
  } else {
    noSubsection.push(post);
  }
}

const hasSubsections = subsectionMap.size > 0;
let globalNum = 1;
---

<BaseLayout
  title={meta?.title ?? seriesKey}
  description={meta?.description}
  bodyClass="pattern-grid"
>
  <div class="container page-wrap">
    <nav class="breadcrumb">
      <a href="/">~</a>
      <span class="sep">/</span>
      <a href="/salas">salas</a>
      <span class="sep">/</span>
      <span class="current">{seriesKey}</span>
    </nav>

    <header class="area-header">
      <div class="area-icon-wrap" style={`background: ${meta?.color}18; border-color: ${meta?.color}40`}>
        <span class="area-icon">{meta?.icon ?? '📚'}</span>
      </div>
      <div class="area-info">
        <p class="area-label">// área de estudio</p>
        <h1 class="area-title">{meta?.title ?? seriesKey}</h1>
        {meta?.description && <p class="area-desc">{meta.description}</p>}
      </div>
      <span class="area-count">{posts.length} {posts.length === 1 ? 'nota' : 'notas'}</span>
    </header>

    {posts.length === 0 && (
      <p class="empty">No hay notas en esta área todavía.</p>
    )}

    {hasSubsections ? (
      // Sala con subsecciones: mostrar cards de subsección
      <div class="subsection-grid">
        {[...subsectionMap.entries()].map(([subKey, subPosts]) => {
          const subSlug = toSlug(subKey);
          const preview = subPosts.slice(0, 3);
          return (
            <a href={`/salas/${seriesKey}/${subSlug}`} class="sub-card">
              <div class="card-accent" style={`background: ${meta?.color}`}></div>
              <div class="card-body">
                <div class="card-head">
                  <div class="card-titles">
                    <h2 class="card-title">{subKey}</h2>
                  </div>
                  <span class="card-count">{subPosts.length}</span>
                </div>
                {preview.length > 0 && (
                  <ul class="card-preview">
                    {preview.map(p => (
                      <li class="preview-item">
                        <span class="preview-dot">·</span>
                        <span class="preview-title">{p.data.title}</span>
                      </li>
                    ))}
                    {subPosts.length > 3 && (
                      <li class="preview-item preview-more">
                        <span class="preview-dot">·</span>
                        <span>+{subPosts.length - 3} más</span>
                      </li>
                    )}
                  </ul>
                )}
                <div class="card-footer">
                  <span class="card-cta">explorar →</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      // Sala sin subsecciones: listar posts directamente
      <div class="post-list">
        {posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.slug}
            series={seriesKey}
            num={i + 1}
            readingTime={readingTime(post.body)}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 36px;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { opacity: 0.4; }
  .breadcrumb .current { color: var(--accent); }

  /* Header */
  .area-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 44px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .area-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .area-icon { font-size: 1.6rem; }

  .area-info { flex: 1; min-width: 0; }

  .area-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .area-title {
    font-family: var(--display);
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: var(--text-bright);
    margin-bottom: 8px;
  }

  .area-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.6;
    font-weight: 300;
    max-width: 560px;
  }

  .area-count {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 3px;
    white-space: nowrap;
    align-self: flex-start;
  }

  /* Grid de subsecciones */
  .subsection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
  }

  .sub-card {
    display: flex;
    flex-direction: column;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.15s;
  }

  .sub-card:hover {
    border-color: var(--border-light, rgba(255,255,255,0.12));
    transform: translateY(-2px);
  }

  .card-accent {
    height: 3px;
    width: 100%;
    opacity: 0.7;
    flex-shrink: 0;
  }

  .card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }

  .card-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .card-titles { flex: 1; min-width: 0; }

  .card-title {
    font-family: var(--display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-bright);
  }

  .card-count {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 2px;
    white-space: nowrap;
    align-self: flex-start;
  }

  .card-preview {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 12px;
    background: var(--bg3);
    border-radius: 4px;
  }

  .preview-item {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .preview-dot {
    font-family: var(--mono);
    color: var(--accent);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .preview-title {
    font-size: 0.78rem;
    color: var(--text-dim);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .preview-more {
    opacity: 0.6;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  .card-footer { margin-top: auto; }

  .card-cta {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    transition: color 0.2s;
  }

  .sub-card:hover .card-cta { color: var(--accent); }

  /* Posts (sin subsecciones) */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .empty {
    font-family: var(--mono);
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .subsection-grid { grid-template-columns: 1fr; }
  }
</style>
