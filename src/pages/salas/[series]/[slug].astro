---
import PostLayout from '../../../layouts/PostLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', p => !p.data.draft && !!p.data.series);
  return posts.map(post => ({
    params: { series: post.data.series!, slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const allPosts = await getCollection('posts', p => !p.data.draft);
const seriesPosts = post.data.series
  ? allPosts.filter(p => p.data.series === post.data.series)
  : [];
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  tags={post.data.tags}
  excerpt={post.data.excerpt}
  headings={headings}
  series={post.data.series}
  seriesPosts={seriesPosts}
  currentSlug={post.slug}
  usefulFor={post.data.usefulFor}
>
  <Content />
</PostLayout>
