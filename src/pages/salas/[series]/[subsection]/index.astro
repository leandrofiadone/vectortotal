---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { SERIES } from '../../../../data/series';

function toSlug(str: string) {
  return str.toLowerCase().replace(/\s+/g, '-');
}

function readingTime(body: string): number {
  const text = body
    .replace(/^---[\s\S]*?---/, '')
    .replace(/<[^>]+>/g, ' ')
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`[^`]+`/g, ' ');
  const words = text.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

export async function getStaticPaths() {
  function toSlug(str: string) {
    return str.toLowerCase().replace(/\s+/g, '-');
  }

  const allPosts = await getCollection('posts', p => !p.data.draft && !!p.data.subsection);
  const paths = new Map<string, { series: string; subsection: string; label: string }>();

  for (const post of allPosts) {
    const series = post.data.series!;
    const label = post.data.subsection!;
    const subsection = toSlug(label);
    const key = `${series}/${subsection}`;
    if (!paths.has(key)) paths.set(key, { series, subsection, label });
  }

  return [...paths.values()].map(({ series, subsection, label }) => ({
    params: { series, subsection },
    props: { label },
  }));
}

interface Props { label: string; }

const { series: seriesKey, subsection: subsectionSlug } = Astro.params;
const { label } = Astro.props;
const meta = SERIES[seriesKey];

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.series === seriesKey && p.data.subsection && toSlug(p.data.subsection) === subsectionSlug)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<BaseLayout
  title={`${label} — ${meta?.title ?? seriesKey}`}
  description={`Notas de ${label}`}
>
  <div class="container page-wrap">
    <nav class="breadcrumb">
      <a href="/">~</a>
      <span class="sep">/</span>
      <a href="/salas">salas</a>
      <span class="sep">/</span>
      <a href={`/salas/${seriesKey}`}>{seriesKey}</a>
      <span class="sep">/</span>
      <span class="current">{subsectionSlug}</span>
    </nav>

    <header class="area-header">
      <div class="area-icon-wrap" style={`background: ${meta?.color}18; border-color: ${meta?.color}40`}>
        <span class="area-icon">{meta?.icon ?? '📚'}</span>
      </div>
      <div class="area-info">
        <p class="area-label">// {meta?.title ?? seriesKey}</p>
        <h1 class="area-title">{label}</h1>
      </div>
      <span class="area-count">{posts.length} {posts.length === 1 ? 'nota' : 'notas'}</span>
    </header>

    {posts.length === 0 && (
      <p class="empty">No hay notas en esta subsección todavía.</p>
    )}

    <div class="post-list">
      {posts.map((post, i) => (
        <PostCard
          title={post.data.title}
          excerpt={post.data.excerpt}
          date={post.data.date}
          tags={post.data.tags}
          slug={post.slug}
          series={seriesKey}
          subsection={subsectionSlug}
          num={i + 1}
          readingTime={readingTime(post.body)}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 36px;
  }

  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb .sep { opacity: 0.4; }
  .breadcrumb .current { color: var(--accent); }

  .area-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 44px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .area-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .area-icon { font-size: 1.6rem; }
  .area-info { flex: 1; min-width: 0; }

  .area-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .area-title {
    font-family: var(--display);
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: var(--text-bright);
  }

  .area-count {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 3px;
    white-space: nowrap;
    align-self: flex-start;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .empty {
    font-family: var(--mono);
    color: var(--text-dim);
    font-size: 0.85rem;
  }
</style>
