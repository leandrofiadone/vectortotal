---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: {
    publishedTime: string;
    tags: string[];
  };
}

const {
  title,
  description = 'vectortotal — apuntes de seguridad ofensiva, redes y CTFs. En español.',
  ogImage,
  article,
} = Astro.props;

const siteTitle = title === 'vectortotal' ? 'vectortotal' : `${title} — vectortotal`;
const siteURL   = (Astro.site?.toString() ?? 'https://vectortotal.vercel.app').replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = `${siteURL}${ogImage ?? '/og-default.svg'}`;

const jsonLD = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      url: canonical.toString(),
      datePublished: article.publishedTime,
      inLanguage: 'es',
      author: {
        '@type': 'Person',
        name: 'Leandro Fiadone',
        url: 'https://leanfiadone.vercel.app/',
      },
      publisher: {
        '@type': 'Organization',
        name: 'vectortotal',
        url: siteURL,
      },
      keywords: article.tags.join(', '),
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'vectortotal',
      url: siteURL,
      description,
      inLanguage: 'es',
      author: {
        '@type': 'Person',
        name: 'Leandro Fiadone',
        url: 'https://leanfiadone.vercel.app/',
      },
    };
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO base -->
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="vectortotal" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />
    {article && <meta property="article:published_time" content={article.publishedTime} />}
    {article?.tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@400;700;800&family=DM+Sans:ital,wght@0,300;0,400;1,300&display=swap"
      rel="stylesheet"
    />

    <!-- View Transitions -->
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
</html>
