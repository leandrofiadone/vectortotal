---
import { createHash } from 'node:crypto';

interface Props {
  answer: string;
  type?: string;
  hash?: string;
  difficulty?: 1 | 2 | 3;
  hint?: string;
  context?: string;
}

const { answer, type = 'MD5', hash, difficulty = 1, hint, context } = Astro.props;

// Compute display hash at build time if not provided
const algoMap: Record<string, string> = {
  'md5': 'md5', 'sha-1': 'sha1', 'sha1': 'sha1',
  'sha-256': 'sha256', 'sha256': 'sha256',
};
const algo = algoMap[type.toLowerCase()];
const displayHash = hash || (algo ? createHash(algo).update(answer).digest('hex') : '');

// SHA-256 of the answer — only THIS reaches the client, never the answer itself
const verify = createHash('sha256').update(answer).digest('hex');

const dots = '■'.repeat(difficulty) + '□'.repeat(3 - difficulty);
---

<div class="hash-challenge" data-verify={verify}>
  <div class="challenge-bar">
    <span class="challenge-type">{type.toUpperCase()}</span>
    <span class="challenge-diff" title={`dificultad ${difficulty}/3`}>{dots}</span>
  </div>
  <div class="challenge-body">
    {context && <p class="challenge-context">{context}</p>}
    <div class="challenge-hash">{displayHash}</div>
    <div class="challenge-input-row">
      <input
        type="text"
        class="challenge-answer"
        placeholder="plaintext"
        autocomplete="off"
        spellcheck="false"
      />
      <button class="challenge-btn">verificar</button>
    </div>
    <div class="challenge-result"></div>
    {hint && (
      <details class="challenge-hint">
        <summary class="challenge-hint-toggle">pista</summary>
        <p class="challenge-hint-text">{hint}</p>
      </details>
    )}
  </div>
</div>

<script>
document.addEventListener('astro:page-load', () => {
  document.querySelectorAll('.hash-challenge').forEach(container => {
    const verify = container.getAttribute('data-verify')!;
    const input = container.querySelector<HTMLInputElement>('.challenge-answer')!;
    const btn = container.querySelector<HTMLButtonElement>('.challenge-btn')!;
    const result = container.querySelector<HTMLElement>('.challenge-result')!;

    let solved = false;

    async function check() {
      if (solved) return;
      const guess = input.value.trim();
      if (!guess) return;

      const data = new TextEncoder().encode(guess);
      const buffer = await crypto.subtle.digest('SHA-256', data);
      const bytes = new Uint8Array(buffer);
      const hex = Array.from(bytes).map(b => b.toString(16).padStart(2, '0')).join('');

      if (hex === verify) {
        solved = true;
        container.classList.add('solved');
        container.classList.remove('wrong');
        result.textContent = '✓ crackeado';
        result.className = 'challenge-result result-success';
        input.readOnly = true;
        btn.textContent = '✓';
        btn.disabled = true;
      } else {
        container.classList.add('wrong');
        result.textContent = '✗ seguí intentando';
        result.className = 'challenge-result result-fail';
        setTimeout(() => container.classList.remove('wrong'), 500);
      }
    }

    btn.addEventListener('click', check);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') check();
    });
  });
});
</script>

<style>
  .hash-challenge {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    font-family: var(--mono);
    margin: 1rem 0;
    transition: border-color 0.4s ease;
  }

  .hash-challenge.solved {
    border-color: #2ed573;
  }

  .hash-challenge.wrong {
    animation: shake 0.4s ease;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-5px); }
    40% { transform: translateX(5px); }
    60% { transform: translateX(-3px); }
    80% { transform: translateX(3px); }
  }

  .challenge-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 14px;
    background: rgba(0,0,0,0.3);
    border-bottom: 1px solid var(--border);
  }

  .challenge-type {
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 600;
    background: rgba(0, 229, 255, 0.08);
    padding: 2px 10px;
    border-radius: 3px;
    letter-spacing: 0.05em;
  }

  .challenge-diff {
    font-size: 0.7rem;
    color: var(--accent3);
    letter-spacing: 3px;
  }

  .challenge-body {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .challenge-context {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .challenge-hash {
    font-size: 0.76rem;
    color: var(--text-bright);
    word-break: break-all;
    background: var(--bg3);
    padding: 10px 12px;
    border-radius: 4px;
    border-left: 2px solid var(--accent);
    line-height: 1.7;
    user-select: all;
    transition: border-color 0.4s;
  }

  .hash-challenge.solved .challenge-hash {
    border-left-color: #2ed573;
  }

  .challenge-input-row {
    display: flex;
    gap: 8px;
  }

  .challenge-answer {
    flex: 1;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 7px 10px;
    color: var(--text-bright);
    font-family: var(--mono);
    font-size: 0.82rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .challenge-answer:focus {
    border-color: var(--accent);
  }

  .challenge-answer::placeholder {
    color: var(--text-dim);
    opacity: 0.5;
  }

  .hash-challenge.solved .challenge-answer {
    border-color: #2ed573;
    color: #2ed573;
  }

  .challenge-btn {
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.78rem;
    padding: 7px 16px;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.3s, color 0.3s;
    white-space: nowrap;
  }

  .challenge-btn:hover:not(:disabled) {
    background: rgba(0, 229, 255, 0.18);
  }

  .challenge-btn:disabled {
    border-color: #2ed573;
    color: #2ed573;
    cursor: default;
  }

  .challenge-result {
    font-size: 0.8rem;
    min-height: 1.2em;
    font-weight: 600;
  }

  .result-success { color: #2ed573; }
  .result-fail { color: var(--accent2); }

  .challenge-hint {
    border-top: 1px solid var(--border);
    padding-top: 8px;
  }

  .challenge-hint-toggle {
    font-size: 0.72rem;
    color: var(--text-dim);
    cursor: pointer;
    user-select: none;
    letter-spacing: 0.04em;
  }

  .challenge-hint-toggle:hover {
    color: var(--text);
  }

  .challenge-hint-text {
    font-size: 0.8rem;
    color: var(--text);
    margin: 6px 0 0;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .challenge-hash { font-size: 0.68rem; }
    .challenge-answer { font-size: 0.78rem; }
  }
</style>
