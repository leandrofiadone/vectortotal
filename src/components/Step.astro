---
interface Props {
  n: number;
  title: string;
  label?: string;
  last?: boolean;
}

const { n, title, label, last = false } = Astro.props;
---

<div class="step">
  <div class="step-left">
    <div class="step-circle">{n}</div>
    {!last && <div class="step-line"></div>}
  </div>
  <div class="step-right">
    <div class="step-header">
      <span class="step-title">{title}</span>
      {label && <span class="step-badge">{label}</span>}
    </div>
    <div class="step-body">
      <slot />
    </div>
  </div>
</div>

<style>
  .step {
    display: flex;
    gap: 18px;
  }

  .step-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .step-circle {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--bg3);
    border: 2px solid var(--accent);
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.9rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .step-line {
    flex: 1;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), var(--border));
    margin: 6px 0;
    min-height: 24px;
    opacity: 0.4;
  }

  .step-right {
    padding-top: 7px;
    padding-bottom: 28px;
    min-width: 0;
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .step-title {
    font-family: var(--display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-bright);
  }

  .step-badge {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--accent);
    border: 1px solid rgba(0, 229, 255, 0.3);
    background: rgba(0, 229, 255, 0.07);
    padding: 2px 8px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .step-body {
    color: var(--text);
    font-family: var(--body);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* Estilos para contenido MDX dentro del slot */
  .step-body :global(p)      { margin-bottom: 0.6em; }
  .step-body :global(ul)     { padding-left: 1.2em; margin-top: 6px; }
  .step-body :global(li)     { margin-bottom: 4px; font-size: 0.9rem; color: var(--text-dim); }
  .step-body :global(li::marker) { color: var(--accent); }
  .step-body :global(strong) { color: var(--text-bright); font-weight: 700; }

  .step-body :global(code) {
    font-family: var(--mono);
    font-size: 0.82em;
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.2);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--accent);
  }
</style>
