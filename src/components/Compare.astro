---
interface Props {
  headers: string[];
  rows: string[][];
  colors?: string[];
  icons?: string[];
}
const { headers, rows, colors = [], icons = [] } = Astro.props;
const colCount = headers.length;
---

<div class="compare" style={`--col-count: ${colCount}`}>
  <div class="compare-header">
    <div class="compare-corner"></div>
    {headers.map((h, i) => (
      <div class="compare-col" style={colors[i] ? `--col-clr: ${colors[i]}` : ''}>
        {icons[i] && <span class="col-icon">{icons[i]}</span>}
        <span class="col-title">{h}</span>
      </div>
    ))}
  </div>
  <div class="compare-rows">
    {rows.map(row => (
      <div class="compare-row">
        <div class="row-label">{row[0]}</div>
        {row.slice(1).map(cell => (
          <div class="row-cell">{cell}</div>
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .compare {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin: 1.5rem 0;
    background: var(--bg2);
  }

  .compare-header,
  .compare-row {
    display: grid;
    grid-template-columns: 140px repeat(var(--col-count), 1fr);
  }

  .compare-corner {
    padding: 0.8rem 1rem;
    background: var(--bg3);
  }

  .compare-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.8rem 0.6rem;
    background: var(--bg3);
    border-left: 1px solid var(--border);
    text-align: center;
  }

  .col-icon { font-size: 1.3rem; }

  .col-title {
    font-family: var(--mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--col-clr, var(--accent));
  }

  .compare-header {
    border-bottom: 2px solid var(--border);
  }

  .compare-row {
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .compare-row:last-child { border-bottom: none; }
  .compare-row:hover { background: rgba(0, 229, 255, 0.03); }

  .row-label {
    padding: 0.65rem 1rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--text-dim);
    display: flex;
    align-items: center;
  }

  .row-cell {
    padding: 0.65rem 0.8rem;
    font-size: 0.88rem;
    color: var(--text);
    border-left: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .compare { overflow-x: auto; }
    .compare-header,
    .compare-row { min-width: 460px; }
    .row-label { font-size: 0.78rem; padding: 0.5rem 0.8rem; }
    .row-cell { font-size: 0.82rem; padding: 0.5rem 0.6rem; }
  }
</style>
