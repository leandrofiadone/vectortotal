---
interface Props {
  question: string;
  hint?: string;
}
const { question, hint } = Astro.props;
---

<div class="quiz">
  <div class="quiz-header">
    <span class="quiz-icon" aria-hidden="true">?</span>
    <p class="quiz-question">{question}</p>
  </div>
  {hint && <p class="quiz-hint">💡 {hint}</p>}
  <details class="quiz-reveal">
    <summary class="quiz-toggle">Mostrar respuesta</summary>
    <div class="quiz-answer">
      <slot />
    </div>
  </details>
</div>

<style>
  .quiz {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent3);
    border-radius: 8px;
    background: var(--bg2);
    margin: 1.5rem 0;
    overflow: hidden;
  }

  .quiz-header {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 1rem 1.2rem 0.6rem;
  }

  .quiz-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--accent3);
    color: var(--bg);
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.9rem;
  }

  .quiz-question {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-bright);
    line-height: 1.6;
    padding-top: 0.15rem;
  }

  .quiz-hint {
    margin: 0;
    padding: 0 1.2rem 0.6rem 3.6rem;
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .quiz-reveal {
    border-top: 1px solid var(--border);
  }

  .quiz-toggle {
    display: block;
    padding: 0.7rem 1.2rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--accent);
    cursor: pointer;
    user-select: none;
    list-style: none;
    transition: background 0.2s;
  }

  .quiz-toggle::-webkit-details-marker { display: none; }
  .quiz-toggle::marker { display: none; content: ''; }

  .quiz-toggle:hover { background: var(--bg3); }

  details[open] > .quiz-toggle {
    border-bottom: 1px solid var(--border);
    color: var(--accent3);
  }

  .quiz-answer {
    padding: 1rem 1.2rem;
    font-size: 0.93rem;
    color: var(--text);
    line-height: 1.7;
  }

  .quiz-answer :global(p) { margin: 0.5rem 0; }
  .quiz-answer :global(p:first-child) { margin-top: 0; }
  .quiz-answer :global(code) {
    font-size: 0.88em;
    background: var(--bg3);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }
  .quiz-answer :global(pre) { margin: 0.8rem 0; }
  .quiz-answer :global(ul) { margin: 0.5rem 0; padding-left: 1.2rem; }
</style>
