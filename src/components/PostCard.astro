---
import { getTagColor } from '../data/tags';
interface Props {
  title: string;
  excerpt: string;
  date: Date;
  tags: string[];
  difficulty?: 'easy' | 'medium' | 'hard';
  slug: string;
  series?: string;
  subsection?: string;
  num: number;
  readingTime?: number;
}

const { title, excerpt, date, tags, difficulty, slug, series, subsection, num, readingTime } = Astro.props;
const href = series && subsection
  ? `/salas/${series}/${subsection}/${slug}`
  : series
    ? `/salas/${series}/${slug}`
    : `/salas/${slug}`;

const difficultyMap = {
  easy:   { label: 'fácil',  cls: 'diff-easy' },
  medium: { label: 'medio',  cls: 'diff-med' },
  hard:   { label: 'difícil', cls: 'diff-hard' },
};

const diff = difficulty ? difficultyMap[difficulty] : null;

const formattedDate = date.toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});

const numStr = String(num).padStart(2, '0');

// Reconstruir label legible desde slug: "network-essentials" → "Network Essentials"
const subsectionLabel = subsection
  ? subsection.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
  : null;
---

<a href={href} class="post-card">
  <span class="post-num">#{numStr}</span>
  <div class="post-body">
    {subsectionLabel && (
      <span class="subsection-badge">{subsectionLabel}</span>
    )}
    <h3 class="post-title" transition:name={`post-title-${slug}`}>{title}</h3>
    <p class="post-excerpt">{excerpt}</p>
    <div class="post-footer">
      <div class="post-tags">
        {tags.map(t => {
          const c = getTagColor(t);
          return <span class="tag" style={`color: ${c}; border-color: ${c}33; background: ${c}12;`}>{t}</span>;
        })}
        {diff && <span class:list={['diff-badge', diff.cls]}>{diff.label}</span>}
      </div>
      <div class="post-meta">
        <span class="post-date">{formattedDate}</span>
        {readingTime && (
          <>
            <span class="meta-sep">·</span>
            <span class="post-read">{readingTime} min</span>
          </>
        )}
      </div>
    </div>
  </div>
  <span class="post-arrow">→</span>
</a>

<style>
  .post-card {
    display: grid;
    grid-template-columns: 48px 1fr 24px;
    align-items: center;
    gap: 16px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg2);
    color: inherit;
    text-decoration: none;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
    transform: scaleY(0);
    transition: transform 0.2s;
    transform-origin: bottom;
    z-index: 1;
  }

  .post-card:hover {
    background: var(--bg3);
    border-color: rgba(0, 229, 255, 0.2);
  }

  .post-card:hover::before { transform: scaleY(1); }

  .post-num {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    align-self: start;
    padding-top: 2px;
  }

  .post-body {
    min-width: 0;
  }

  .subsection-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    opacity: 0.7;
    margin-bottom: 4px;
  }

  .post-title {
    font-family: var(--display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 6px;
    line-height: 1.3;
    transition: color 0.2s;
  }

  .post-card:hover .post-title { color: var(--accent); }

  .post-excerpt {
    font-size: 0.875rem;
    color: var(--text-dim);
    line-height: 1.5;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
  }

  .post-date,
  .post-read,
  .meta-sep {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .meta-sep { opacity: 0.4; }

  .post-arrow {
    font-family: var(--mono);
    color: var(--text-dim);
    font-size: 0.9rem;
    transition: color 0.2s, transform 0.2s;
    display: inline-block;
    align-self: center;
  }

  .post-card:hover .post-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .post-card { grid-template-columns: 36px 1fr; }
    .post-arrow { display: none; }
  }
</style>
