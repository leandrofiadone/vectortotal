---
const year = new Date().getFullYear();
---

<footer class="site-footer" transition:animate="none">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="vectortotal — inicio">
        <span class="footer-name">vectortotal</span>
      </a>
    </div>

    <div class="footer-links">
      <a href="https://github.com/leandrofiadone" target="_blank" rel="noopener noreferrer" class="footer-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <span class="footer-sep">·</span>
      <a href="https://leanfiadone.vercel.app/" target="_blank" rel="noopener noreferrer" class="footer-link">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        Portfolio
      </a>
      <span class="footer-sep">·</span>
      <span class="footer-year">{year}</span>
    </div>
  </div>
  <div class="footer-bar"></div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    border-top: 1px solid var(--border);
    background: var(--bg2);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 24px;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-brand { display: flex; align-items: baseline; }

  .footer-logo {
    display: flex;
    align-items: baseline;
    gap: 6px;
    text-decoration: none;
  }

  .footer-name {
    font-family: var(--mono);
    font-size: 0.95rem;
    color: var(--accent);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.04em;
  }

  .footer-link:hover { color: var(--accent); }

  .footer-sep {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--border);
  }

  .footer-year {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    opacity: 0.5;
  }

  .footer-bar {
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, #00e5ff 30%, #a78bfa 60%, #ff4757 85%, transparent 100%);
    opacity: 0.4;
  }
</style>
