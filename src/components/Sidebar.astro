---
import { SERIES } from '../data/series';
import { getCollection } from 'astro:content';
import { toSlug } from '../utils/slug';
import { getTagColor } from '../data/tags';

interface Props {
  categoryCounts: Record<string, number>;
}

const { categoryCounts } = Astro.props;

const categories = Object.entries(categoryCounts).sort((a, b) => b[1] - a[1]);

// Calcular subsecciones por serie
const allPosts = await getCollection('posts', p => !p.data.draft && !!p.data.subsection);
const subsectionsBySeries = new Map<string, { label: string; slug: string }[]>();
for (const post of allPosts) {
  const series = post.data.series!;
  const label = post.data.subsection!;
  const slug = toSlug(label);
  if (!subsectionsBySeries.has(series)) subsectionsBySeries.set(series, []);
  const existing = subsectionsBySeries.get(series)!;
  if (!existing.find(s => s.slug === slug)) existing.push({ label, slug });
}

const seriesEntries = Object.entries(SERIES);
---

<aside class="sidebar">
  <!-- Widget: Áreas de estudio -->
  <div class="widget">
    <h4 class="widget-title"><span class="accent">$</span> áreas</h4>
    <ul class="series-list">
      {seriesEntries.map(([key, meta]) => {
        const subsections = subsectionsBySeries.get(key) ?? [];
        const hasSubsections = subsections.length > 0;
        return (
          <li class="series-item">
            <a href={`/salas/${key}`} class="series-link">
              <span class="series-icon">{meta.icon}</span>
              <span class="series-name">{meta.title}</span>
              {hasSubsections && <span class="series-chevron">›</span>}
            </a>
            {hasSubsections && (
              <ul class="subsection-list">
                {subsections.map(sub => (
                  <li>
                    <a href={`/salas/${key}/${sub.slug}`} class="subsection-link">
                      <span class="sub-dot">·</span>
                      {sub.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        );
      })}
    </ul>
  </div>

  <!-- Widget: Tags -->
  <div class="widget">
    <h4 class="widget-title"><span class="accent">$</span> tags</h4>
    <ul class="cat-list">
      {categories.map(([cat, count]) => (
        <li class="cat-item">
          <a href={`/tags/${cat}`} class="cat-link">
            <span
              class="cat-dot"
              style={`background: ${getTagColor(cat)}`}
            ></span>
            <span class="cat-name">{cat}</span>
          </a>
          <span class="cat-count">{count}</span>
        </li>
      ))}
      {categories.length === 0 && (
        <li class="cat-empty">Sin salas aún</li>
      )}
    </ul>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .widget {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px;
  }

  .widget-title {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .accent { color: var(--accent); }

  /* Series */
  .series-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .series-item {}

  .series-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--text-dim);
    text-decoration: none;
    padding: 5px 6px;
    border-radius: 3px;
    transition: all 0.2s;
  }

  .series-link:hover {
    color: var(--text-bright);
    background: rgba(255, 255, 255, 0.04);
  }

  .series-icon { font-size: 0.95rem; }
  .series-name { font-family: var(--body); font-size: 0.82rem; flex: 1; }

  .series-chevron {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    opacity: 0.5;
    margin-left: auto;
    transition: transform 0.2s;
  }

  .series-item:hover .series-chevron { opacity: 1; }

  .subsection-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding-left: 26px;
    margin-top: 2px;
    margin-bottom: 4px;
  }

  .subsection-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.76rem;
    color: var(--text-dim);
    text-decoration: none;
    padding: 3px 6px;
    border-radius: 3px;
    transition: color 0.15s, background 0.15s;
  }

  .subsection-link:hover {
    color: var(--accent);
    background: rgba(255, 255, 255, 0.03);
  }

  .sub-dot {
    font-family: var(--mono);
    color: var(--accent);
    opacity: 0.5;
    font-size: 0.8rem;
  }

  /* Categories */
  .cat-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cat-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cat-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    padding: 4px 6px;
    border-radius: 3px;
    flex: 1;
    text-decoration: none;
    transition: color 0.2s;
  }

  .cat-link:hover {
    color: var(--text-bright);
  }

  .cat-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .cat-count {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    background: var(--bg3);
    padding: 1px 6px;
    border-radius: 2px;
  }

  .cat-empty {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-dim);
  }
</style>
