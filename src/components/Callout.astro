---
interface Props {
  type?: 'tip' | 'warning' | 'danger' | 'info';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const config = {
  tip:     { icon: '💡', label: 'Tip'        },
  warning: { icon: '⚠️', label: 'Atención'   },
  danger:  { icon: '🔥', label: 'Importante' },
  info:    { icon: 'ℹ️', label: 'Nota'       },
};

const cfg = config[type];
---

<div class={`callout callout-${type}`}>
  <span class="callout-icon">{cfg.icon}</span>
  <div class="callout-body">
    <span class="callout-label">{title ?? cfg.label}</span>
    <slot />
  </div>
</div>

<style>
  .callout {
    display: flex;
    gap: 14px;
    padding: 14px 18px;
    border-radius: 4px;
    border-left: 3px solid;
    margin: 1.5em 0;
    font-size: 0.92rem;
    line-height: 1.65;
    align-items: flex-start;
  }

  .callout-info    { background: rgba(0, 229, 255, 0.06);  border-color: #00e5ff; }
  .callout-tip     { background: rgba(39, 201, 63, 0.06);  border-color: #27c93f; }
  .callout-warning { background: rgba(255, 211, 42, 0.06); border-color: #ffd32a; }
  .callout-danger  { background: rgba(255, 71, 87, 0.06);  border-color: #ff4757; }

  .callout-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 1px;
    line-height: 1.4;
  }

  .callout-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .callout-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    opacity: 0.7;
  }

  .callout-info    .callout-label { color: #00e5ff; }
  .callout-tip     .callout-label { color: #27c93f; }
  .callout-warning .callout-label { color: #ffd32a; }
  .callout-danger  .callout-label { color: #ff4757; }
</style>
